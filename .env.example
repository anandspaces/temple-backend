PORT=3000
MONGO_URI=mongodb://localhost:27017/temple
OTP_EXPIRY_MINUTES=5
# For testing: use this OTP instead of random
TEST_OTP=123456
JWT_SECRET=your-secret-min-32-chars
# Access token and session lifetime: Nd, Nh, Nm, Ns (e.g. 30d, 7d, 24h)
JWT_EXPIRES_IN=30d
# Optional: base URL for absolute file URLs in responses
API_BASE_URL=http://localhost:3000
LOG_LEVEL=info
NODE_ENV=development
